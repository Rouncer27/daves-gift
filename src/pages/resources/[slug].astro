---
// @ts-ignore
// @ts-nocheck
import Layout from "../../layouts/Layout.astro";

import { Page_Seo_Query } from "../../data/page/queries";

import { Post_Featured_Image_Query } from "../../data/resourcesPost/queries";

export async function getStaticPaths() {
  const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
    method: "POST",
    headers: {
      "content-type": "application/json",
    },
    body: JSON.stringify({
      query: `
        query postQuery {
            posts(first: 999999) {
                nodes {
                    slug
                    uri
                }
            }
        }
      `,
    }),
  });

  const { data } = await response.json();
  const allPosts = data.posts.nodes;
  return allPosts.map((post, index) => {
    return {
      params: { slug: `${post.slug}` },
      props: {
        next:
          index === 0
            ? null
            : {
                slug: allPosts[index - 1].slug,
                title: allPosts[index - 1].title,
              },
        prev:
          index === allPosts.length - 1
            ? null
            : {
                slug: allPosts[index + 1].slug,
                title: allPosts[index + 1].title,
              },
      },
    };
  });
}

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
    query postQuery($id: ID!) {
        post(idType: SLUG, id: $id) {
          ${Page_Seo_Query}
          title
          date
          slug
          postType {
            ${Post_Featured_Image_Query}
          }
        }
    }
    `,
    variables: {
      id: Astro.params["slug"],
    },
  }),
});

const {
  data: { post },
} = await response.json();
---

<Layout>
  <h1>Single Post Type</h1>
</Layout>
