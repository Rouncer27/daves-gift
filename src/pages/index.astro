---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Home/Hero/Hero.astro";
import Intro from "../components/Home/Intro/Intro.astro";

import { Page_Seo_Query } from "../data/page/queries";
import { Hero_Query, Intro_Query } from "../data/home/queries";

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		  query homePageQuery {
		    page(id: "/", idType: URI) {
          ${Page_Seo_Query}
            homeTemplate {
              ${Hero_Query}
              ${Intro_Query}
            }
          }
        }
	  `,
  }),
});

const {
  data: {
    page: { seoMetaTags, homeTemplate },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={true}
>
  <Hero data={homeTemplate.hero} />
  <Intro data={homeTemplate.intro} />
</Layout>
