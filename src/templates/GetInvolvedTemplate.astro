---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/GetInvolved/Hero/Hero.astro";
import UpcomingEvents from "../components/GetInvolved/UpcomingEvents/UpcomingEvents.astro";
import FourBlocks from "../components/GetInvolved/FourBlocks/FourBlocks.astro";
import PostDisplay from "../components/GetInvolved/PostDisplay/PostDisplay.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Upcoming_Events_Query,
  Four_Blocks_Query,
  All_posts_Query,
  Posts_Display_Query,
} from "../data/getInvolved/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query getInvolvedTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
          template {
          ... on Template_GetInvolved {
              templateName
                  getInvolvedTemplate {
                      ${Hero_Query}
                      ${Upcoming_Events_Query}
                      ${Four_Blocks_Query}
                      ${Posts_Display_Query}
                  }
              }
          }
			}
      ${All_posts_Query}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    posts,
    page: {
      seoMetaTags,
      template: { getInvolvedTemplate },
    },
  },
} = await response.json();

const postsDisplay = [
  ...getInvolvedTemplate.postsDisplay.postOne.nodes,
  ...getInvolvedTemplate.postsDisplay.postTwo.nodes,
];
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={true}
>
  <Hero data={getInvolvedTemplate.hero} />
  <UpcomingEvents data={getInvolvedTemplate.upcomingEvents} />
  <FourBlocks data={getInvolvedTemplate.fourBlocks} />
  <PostDisplay posts={postsDisplay} />
</Layout>
