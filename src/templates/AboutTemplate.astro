---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/About/Hero/Hero.astro";
import MainContent from "../components/About/MainContent/MainContent.astro";
import CurvedImage from "../components/About/CurvedImage/CurvedImage.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Main_Content_Query,
  Curved_Image_Query,
} from "../data/about/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query helpTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
                template {
                ... on Template_About {
                    templateName
                        aboutTemplate {
                            ${Hero_Query}
                            ${Main_Content_Query}
                            ${Curved_Image_Query}
                        }
                    }
                }
			}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    page: {
      seoMetaTags,
      template: { aboutTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={true}
>
  <Hero data={aboutTemplate.hero} />
  <MainContent data={aboutTemplate.mainContent} />
  <CurvedImage data={aboutTemplate.curvedImage} />
</Layout>
