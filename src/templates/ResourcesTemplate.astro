---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Resources/Hero/Hero.astro";
import PostDisplay from "../components/Resources/PostDisplay/PostDisplay.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Post_Display_Query,
  All_posts_Query,
} from "../data/resources/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query resourcesTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
                template {
                ... on Template_Resources {
                    templateName
                        resourcesTemplate {
                            ${Hero_Query}
                            ${Post_Display_Query}
                        }
                    }
                }
			}
            ${All_posts_Query}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    posts,
    page: {
      seoMetaTags,
      template: { resourcesTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={true}
>
  <Hero data={resourcesTemplate.hero} />
  {
    resourcesTemplate.postDisplay.displayPosts ? (
      <PostDisplay posts={posts.edges} />
    ) : null
  }
</Layout>
