---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Donate/Hero/Hero.astro";
import PageIntro from "../components/Donate/PageIntro/PageIntro.astro";
import Embed from "../components/Donate/Embed/Embed.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Page_Intro_Query,
  Embed_Query,
} from "../data/donate/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query donateTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
                template {
                ... on Template_Donate {
                    templateName
                        donateTemplate {
                            ${Hero_Query}
                            ${Page_Intro_Query}
                            ${Embed_Query}
                        }
                    }
                }
			}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    page: {
      seoMetaTags,
      template: { donateTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={true}
>
  <Hero data={donateTemplate.hero} />
  <PageIntro data={donateTemplate.pageIntro} />
  <Embed data={donateTemplate.embed} />
</Layout>
