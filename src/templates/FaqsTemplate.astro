---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Faqs/Hero/Hero.astro";

import { Page_Seo_Query } from "../data/page/queries";
import { Hero_Query } from "../data/faqs/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query resourcesTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
                template {
                ... on Template_Faqs {
                    templateName
                        faqsTemplate {
                            ${Hero_Query}
                        }
                    }
                }
			}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    page: {
      seoMetaTags,
      template: { faqsTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={true}
>
  <Hero data={faqsTemplate.hero} />
</Layout>
