---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Contact/Hero/Hero.astro";
import ContactInformation from "../components/Contact/ContactInformation/ContactInformation.astro";
import ContactFormDisplay from "../components/Contact/ContactFormDisplay/ContactFormDisplay.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Contact_Information_Query,
  Contact_Form_Display_Query,
} from "../data/contact/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query contactTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
                template {
                ... on Template_Contact {
                    templateName
                        contactTemplate {
                            ${Hero_Query}
                            ${Contact_Information_Query}
                            ${Contact_Form_Display_Query}
                        }
                    }
                }
			}

      siteWideSettings {
        contactInformation {
          phoneNumber
          emailAddress
        }

        socialMedia {
          youtubeLink
          linkedinLink
          instagramLink
          facebookLink
        }
      }
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    siteWideSettings,
    page: {
      seoMetaTags,
      template: { contactTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={true}
>
  <Hero data={contactTemplate.hero} />
  <ContactInformation
    data={contactTemplate.contactInformation}
    contactInformation={siteWideSettings.contactInformation}
    socialMediaLinks={siteWideSettings.socialMedia}
  />
  <ContactFormDisplay data={contactTemplate.contactFormDisplay} />
</Layout>
