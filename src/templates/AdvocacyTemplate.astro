---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Advocacy/Hero/Hero.astro";
import AdvocacyIntro from "../components/Advocacy/AdvocacyIntro/AdvocacyIntro.astro";
import GetInvolved from "../components/Advocacy/GetInvolved/GetInvolved.astro";
import ImageRow from "../components/Advocacy/ImageRow/ImageRow.astro";

import { Page_Seo_Query } from "../data/page/queries";
import {
  Hero_Query,
  Advocacy_Intro_Query,
  Get_Involved_Query,
  Image_Row_Query,
} from "../data/advocacy/queries";

// 2️⃣ Get the actual page data by slug
const { uri } = Astro.params;

const response = await fetch(`${import.meta.env.WPGRAPHQL_URL}`, {
  method: "POST",
  headers: {
    "content-type": "application/json",
  },
  body: JSON.stringify({
    query: `
		query advocacyTempQuery($slug: ID!) {
			page(id: $slug, idType: URI) {
				${Page_Seo_Query}
        template {
        ... on Template_Advocacy {
            templateName
                advocacyTemplate {
                    ${Hero_Query}
                    ${Advocacy_Intro_Query}
                    ${Get_Involved_Query}
                    ${Image_Row_Query}
                }
            }
        }
			}
		}
	`,
    variables: { slug: `${uri}` },
  }),
});

const {
  data: {
    page: {
      seoMetaTags,
      template: { advocacyTemplate },
    },
  },
} = await response.json();
---

<Layout
  metaImg={seoMetaTags.seoMetaInformation.metaImage.sourceUrl}
  metaTitle={seoMetaTags.seoMetaInformation.metaTitle}
  metaDescription={seoMetaTags.seoMetaInformation.metaDescription}
  isHome={true}
>
  <Hero data={advocacyTemplate.hero} />
  <AdvocacyIntro data={advocacyTemplate.advocacyIntro} />
  <GetInvolved data={advocacyTemplate.getInvolved} />
  <ImageRow data={advocacyTemplate.imageRow} />
</Layout>
