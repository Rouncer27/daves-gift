---
// @ts-ignore
// @ts-nocheck
import { Image } from "astro:assets";
import Wrapper from "../../common/shared/Wrapper.astro";
import "./practitioners.scss";
const { title, practitioners } = Astro.props.data;
---

<div class="practitioners">
  <Wrapper classes="practitioners-wrapper">
    <div class="practitioners-title">
      <h2>{title}</h2>
    </div>
    <div class="practitioners-headshots">
      {
        practitioners.map((pract) => {
          const imageSrc = pract.image?.node?.sourceUrl;
          const imageAlt = pract.image?.node?.altText || "";

          return (
            <div class="practitioners-headshot">
              <div>
                <Image
                  src={imageSrc}
                  alt={imageAlt}
                  format="webp"
                  widths={[800, 1200, 1600, 2000]}
                  sizes="100vw"
                  loading="eager"
                  inferSize={true}
                />
              </div>
              <div>
                <h3>{pract.name}</h3>
                <p>
                  <button type="button">click to Read</button>
                </p>
              </div>
            </div>
          );
        })
      }
    </div>
    <div class="practitioners-bios">
      {
        practitioners.map((pract) => {
          return (
            <div class="practitioners-bio">
              <div>
                <div set:html={pract.bio} />
              </div>
            </div>
          );
        })
      }
    </div>
  </Wrapper>
</div>
