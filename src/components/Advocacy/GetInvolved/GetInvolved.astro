---
import { Image } from "astro:assets";
import Button from "../../common/shared/Button.astro";
import Wrapper from "../../common/shared/Wrapper.astro";
import "./getInvolved.scss";

const {
  title,
  content,
  buttonOneText,
  buttonTwoText,
  buttonOneLink,
  buttonTwoLink,
  image,
} = Astro.props.data;

const imageSrc = image?.node?.sourceUrl;
const imageAlt = image?.node?.altText || "";
import mask from "../../../assets/half-circle-cut-beige.png";
---

<div class="get-involved">
  <Wrapper>
    <div class="get-involved-content">
      <div class="get-involved-content-inner">
        <div class="get-involved-content-title">
          <h2>{title}</h2>
        </div>
        <div class="get-involved-content-paragraph" set:html={content} />
        <div class="get-involved-content-buttons">
          <Button ele="a" btnstyle="one" href={buttonOneLink.edges[0].node.uri}
            >{buttonOneText}</Button
          >
          <Button ele="a" btnstyle="one" href={buttonTwoLink.edges[0].node.uri}
            >{buttonTwoText}</Button
          >
        </div>
      </div>
    </div>
    <div class="get-involved-image">
      <div class="get-involved-image-mask">
        <img src={mask.src} alt={"Beige mask"} />
      </div>
      <Image
        src={imageSrc}
        alt={imageAlt}
        format="webp"
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        inferSize={true}
        class=""
      />
    </div>
  </Wrapper>
</div>
