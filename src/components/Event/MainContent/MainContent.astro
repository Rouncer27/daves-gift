---
import Wrapper from "../../common/shared/Wrapper.astro";
import Wysiwyg from "../../common/shared/Wysiwyg.astro";
import "./mainContent.scss";

const { title, content } = Astro.props;
---

<div class="event-article-main">
  <Wrapper>
    <Wysiwyg>
      <div class="event-article-main-title">
        <h1>{title}</h1>
      </div>
      <div class="event-article-main-content" set:html={content} />
    </Wysiwyg>
    <div class="event-article-main-navigation">
      <a href="/get-involved/community-events">Back to All Community Events</a>
    </div>
  </Wrapper>
</div>
