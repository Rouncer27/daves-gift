---
// @ts-ignore
// @ts-nocheck
import { Image } from "astro:assets";
import Wrapper from "../../common/shared/Wrapper.astro";
import "./imageLinks.scss";

const { title, links } = Astro.props.data;
---

<div class="image-links">
  <Wrapper>
    <div class="image-links-title">
      <h2>{title}</h2>
    </div>
    <div class="image-links-container">
      {
        links.map((link) => {
          const imageSrc = link.image?.node?.sourceUrl;
          const imageAlt = link.image?.node?.altText || "";

          return (
            <div class="image-links-link">
              <a href={link.link.edges[0].node.uri}>
                <div>
                  <Image
                    src={imageSrc}
                    alt={imageAlt}
                    format="webp"
                    widths={[800, 1200, 1600, 2000]}
                    sizes="100vw"
                    loading="eager"
                    inferSize={true}
                    class=""
                  />
                </div>
                <div class="image-links-link-title">
                  <h3>{link.title}</h3>
                </div>
              </a>
            </div>
          );
        })
      }
    </div>
  </Wrapper>
</div>
