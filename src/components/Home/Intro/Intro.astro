---
import { Image } from "astro:assets";
import "./intro.scss";

const { image, title, content } = Astro.props.data;

const imageSrc = image?.node?.sourceUrl;
const imageAlt = image?.node?.altText || "";

import mask from "../../../assets/half-circle-cut.png";
---

<div class="home-intro">
  <div class="home-intro-wrapper">
    <div class="home-intro-image">
      <Image
        src={imageSrc}
        alt={imageAlt}
        format="webp"
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        inferSize={true}
        class=""
      />
      <div class="home-intro-image-mask">
        <img src={mask.src} alt={"Green mask"} />
      </div>
    </div>
    <div class="home-intro-content">
      <div class="home-intro-content-inner">
        <div>
          <h2 set:html={title} />
        </div>
        <div set:html={content} />
      </div>
    </div>
  </div>
</div>
