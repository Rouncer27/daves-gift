---
import { Image } from "astro:assets";
import Wrapper from "../../common/shared/Wrapper.astro";
import Button from "../../common/shared/Button.astro";
import "./contentLongImage.scss";

const { topContent, bottomContent, image, buttonLink, buttonText } =
  Astro.props.data;

const imageSrc = image?.node?.sourceUrl;
const imageAlt = image?.node?.altText || "";
---

<div class="content-long">
  <Wrapper classes="content-long-wrapper">
    <div class="content-long-content">
      <div class="content-long-content-top">
        <div set:html={topContent} />
      </div>
      <div class="content-long-content-bottom">
        <div class="content-long-content-bottom-inner">
          <div set:html={bottomContent} />
          <div>
            <Button ele="a" href={buttonLink.edges[0].node.uri}
              >{buttonText}</Button
            >
          </div>
        </div>
      </div>
    </div>
    <div class="content-long-image">
      <Image
        src={imageSrc}
        alt={imageAlt}
        format="webp"
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        inferSize={true}
        class=""
      />
    </div>
  </Wrapper>
</div>
