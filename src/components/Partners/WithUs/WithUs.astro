---
import { Image } from "astro:assets";
import Button from "../../common/shared/Button.astro";
import Wrapper from "../../common/shared/Wrapper.astro";
import "./withUs.scss";

const {
  title,
  content,
  titleBottom,
  contentBottom,
  buttonText,
  buttonUrl,
  image,
} = Astro.props.data;

const imageSrc = image?.node?.sourceUrl;
const imageAlt = image?.node?.altText || "";
import mask from "../../../assets/half-circle-cut-beige.png";
---

<div class="with-us">
  <Wrapper>
    <div class="with-us-content">
      <div class="with-us-content-inner">
        <div class="with-us-content-title">
          <h2>{title}</h2>
        </div>
        <div class="with-us-content-paragraph" set:html={content} />

        <div class="with-us-content-bottitle">
          <h2>{titleBottom}</h2>
        </div>
        <div class="with-us-content-botparagraph" set:html={contentBottom} />
        <div>
          <Button ele="a" btnstyle="one" href={buttonUrl}>{buttonText}</Button>
        </div>
      </div>
    </div>
    <div class="with-us-image">
      <div class="with-us-image-mask">
        <img src={mask.src} alt={"Beige mask"} />
      </div>
      <Image
        src={imageSrc}
        alt={imageAlt}
        format="webp"
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        inferSize={true}
        class=""
      />
    </div>
  </Wrapper>
</div>
