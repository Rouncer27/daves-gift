---
// @ts-ignore
// @ts-nocheck
import Wrapper from "../../common/shared/Wrapper.astro";
import { Image } from "astro:assets";
import "./directors.scss";

const { title, directors } = Astro.props.data;
---

<div class="about-directors">
  <Wrapper classes="about-directors-wrapper">
    <div class="about-directors-title">
      <h2>{title}</h2>
    </div>
    <div class="about-directors-container">
      {
        directors.map((director) => {
          const imageSrc = director.image?.node?.sourceUrl;
          const imageAlt = director.image?.node?.altText || "";
          return (
            <div>
              <div>
                <Image
                  src={imageSrc}
                  alt={imageAlt}
                  format="webp"
                  widths={[800, 1200, 1600, 2000]}
                  sizes="100vw"
                  loading="eager"
                  inferSize={true}
                />
              </div>
              <div>
                <h3>{director.name}</h3>
                <p>{director.title}</p>
              </div>
            </div>
          );
        })
      }
    </div>
  </Wrapper>
</div>
